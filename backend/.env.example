MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=biometric_auth

# Required: Fernet key (32 url-safe base64-encoded bytes)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

JWT_SECRET=replace-with-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ORB good-match count must exceed this for login success
FINGERPRINT_MATCH_THRESHOLD=30

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
